{
  "name": "@edusync/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/discovery",
    "test:integration": "jest --testPathPattern=tests/search",
    "test:smoke": "ts-node ../../scripts/smoke-test.ts",
    "test:load": "k6 run ../../scripts/load-test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@edusync/db": "*",
    "@edusync/shared": "*",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^7.120.4",
    "@types/express-rate-limit": "^5.1.3",
    "axios": "^1.13.6",
    "bullmq": "^5.12.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "html-pdf-node": "^1.0.8",
    "isomorphic-dompurify": "^3.6.0",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.56.0",
    "mongoose": "^8.6.3",
    "multer": "^2.1.1",
    "pg": "^8.12.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.1"
  }
}
