{
  "name": "@edusync/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/nexus-connector.js",
  "types": "./dist/src/nexus-connector.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/nexus-connector.d.ts",
      "import": "./dist/src/nexus-connector.js"
    },
    "./dist/mongo/models/*": {
      "types": "./dist/mongo/models/*.d.ts",
      "import": "./dist/mongo/models/*.js"
    }
  },
  "dependencies": {
    "mongoose": "latest",
    "dotenv": "latest"
  },
  "scripts": {
    "build": "tsc",
    "seed": "tsx ./src/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.5"
  }
}
